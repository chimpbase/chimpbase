{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun-types", "node"],
    "baseUrl": ".",
    "paths": {
      "@chimpbase/core": ["../../packages/core/index.ts"],
      "@chimpbase/runtime": ["../../packages/runtime/index.ts"],
      "@chimpbase/bun": ["../../packages/bun/src/library.ts"]
    }
  },
  "include": ["*.ts"]
}
