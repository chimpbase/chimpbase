{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@chimpbase/core": ["../../../packages/core/index.ts"],
      "@chimpbase/runtime": ["../../../packages/runtime/index.ts"],
      "@chimpbase/bun": ["../../../packages/bun/src/library.ts"]
    }
  },
  "include": ["*.ts", "src/**/*.ts", "src/**/*.d.ts", "tests/**/*.ts"]
}
