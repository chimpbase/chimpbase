    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/build-package.mjs host"
  },
  "dependencies": {
    "@chimpbase/core": "0.3.0",
    "@chimpbase/postgres": "0.3.0",
    "@chimpbase/runtime": "0.3.0",
    "@chimpbase/tooling": "0.3.0",
    "kysely": "^0.28.11"
  }
}
