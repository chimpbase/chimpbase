{
  "name": "@chimpbase/host",
  "version": "0.3.0",
  "description": "Shared host runtime and adapters for Chimpbase runtimes.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimpbase/chimpbase.git",
    "directory": "packages/host"
  },
  "homepage": "https://github.com/chimpbase/chimpbase#readme",
  "bugs": {
    "url": "https://github.com/chimpbase/chimpbase/issues"
  },
  "keywords": [
    "chimpbase",
    "host",
    "runtime",
    "postgres",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
