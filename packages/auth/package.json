{
  "name": "@chimpbase/auth",
  "version": "0.3.0",
  "description": "API key authentication and user management plugin for Chimpbase.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimpbase/chimpbase.git",
    "directory": "packages/auth"
  },
  "homepage": "https://github.com/chimpbase/chimpbase#readme",
  "bugs": {
    "url": "https://github.com/chimpbase/chimpbase/issues"
  },
  "keywords": [
    "chimpbase",
