{
  "name": "@chimpbase/deno",
  "version": "0.4.0",
  "description": "Deno CLI and self-hosted host for Chimpbase.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimpbase/chimpbase.git",
    "directory": "packages/deno"
  },
  "homepage": "https://github.com/chimpbase/chimpbase#readme",
  "bugs": {
    "url": "https://github.com/chimpbase/chimpbase/issues"
  },
  "keywords": [
    "deno",
    "postgres",
    "typescript",
    "workflow",
    "backend"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/library.d.ts",
      "import": "./dist/src/library.js",
      "default": "./dist/src/library.js"
    },
    "./cli": {
      "types": "./dist/src/cli.d.ts",
      "import": "./dist/src/cli.js",
      "default": "./dist/src/cli.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/build-package.mjs deno"
  },
  "dependencies": {
    "@chimpbase/core": "0.4.0",
    "@chimpbase/host": "0.4.0",
    "@chimpbase/postgres": "0.4.0",
    "@chimpbase/runtime": "0.4.0",
    "@chimpbase/tooling": "0.4.0",
    "kysely": "^0.28.11"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
