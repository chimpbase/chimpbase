{
  "name": "@chimpbase/tooling",
  "version": "0.1.27",
  "description": "Local tooling, config loading and CLI helpers for Chimpbase.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimpbase/chimpbase.git",
    "directory": "packages/tooling"
  },
  "homepage": "https://github.com/chimpbase/chimpbase#readme",
  "bugs": {
    "url": "https://github.com/chimpbase/chimpbase/issues"
  },
  "keywords": [
    "chimpbase",
    "tooling",
    "cli",
    "config",
    "schema"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./app": {
      "types": "./dist/src/app.d.ts",
      "import": "./dist/src/app.js",
      "default": "./dist/src/app.js"
    },
    "./cli": {
      "types": "./dist/src/cli.d.ts",
      "import": "./dist/src/cli.js",
      "default": "./dist/src/cli.js"
    },
    "./config": {
      "types": "./dist/src/config.d.ts",
      "import": "./dist/src/config.js",
      "default": "./dist/src/config.js"
    },
    "./migrations": {
      "types": "./dist/src/migrations.d.ts",
      "import": "./dist/src/migrations.js",
      "default": "./dist/src/migrations.js"
    },
    "./postgres_docker": {
      "types": "./dist/src/postgres_docker.d.ts",
      "import": "./dist/src/postgres_docker.js",
      "default": "./dist/src/postgres_docker.js"
    },
    "./schema": {
      "types": "./dist/src/schema.d.ts",
      "import": "./dist/src/schema.js",
      "default": "./dist/src/schema.js"
    },
    "./secrets": {
      "types": "./dist/src/secrets.d.ts",
      "import": "./dist/src/secrets.js",
      "default": "./dist/src/secrets.js"
    },
    "./workflow_contracts": {
      "types": "./dist/src/workflow_contracts.d.ts",
      "import": "./dist/src/workflow_contracts.js",
      "default": "./dist/src/workflow_contracts.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/build-package.mjs tooling"
  },
  "dependencies": {
    "@chimpbase/core": "0.1.27",
    "@chimpbase/runtime": "0.1.27",
    "kysely": "^0.28.11",
    "pg": "^8.16.3"
  }
}
