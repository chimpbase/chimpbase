{
  "name": "@chimpbase/node",
  "version": "0.4.2",
  "description": "Node.js host for building action-driven backends on Postgres or SQLite with minimal boilerplate.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimpbase/chimpbase.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/chimpbase/chimpbase#readme",
  "bugs": {
    "url": "https://github.com/chimpbase/chimpbase/issues"
  },
  "keywords": [
    "node",
    "postgres",
    "sqlite",
    "typescript",
    "workflow",
    "backend"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/library.d.ts",
      "import": "./dist/src/library.js",
      "default": "./dist/src/library.js"
    },
    "./cli": {
      "types": "./dist/src/cli.d.ts",
      "import": "./dist/src/cli.js",
      "default": "./dist/src/cli.js"
    }
  },
  "bin": {
    "chimpbase-node": "./dist/src/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/build-package.mjs node"
  },
  "dependencies": {
    "@chimpbase/core": "0.4.2",
    "@chimpbase/host": "0.4.2",
    "@chimpbase/postgres": "0.4.2",
    "@chimpbase/runtime": "0.4.2",
    "@chimpbase/tooling": "0.4.2",
    "kysely": "^0.28.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3"
  }
}
