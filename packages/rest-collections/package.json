{
  "name": "@chimpbase/rest-collections",
  "version": "0.3.0",
  "description": "Fetch-first REST plugin for exposing Chimpbase collections without hardcoding routes in the runtime.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimpbase/chimpbase.git",
    "directory": "packages/rest-collections"
  },
  "homepage": "https://github.com/chimpbase/chimpbase#readme",
  "bugs": {
    "url": "https://github.com/chimpbase/chimpbase/issues"
  },
  "keywords": [
    "chimpbase",
    "rest",
    "collections",
    "fetch",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/build-package.mjs runtime rest-collections"
  },
  "dependencies": {
    "@chimpbase/runtime": "0.3.0"
  }
}
