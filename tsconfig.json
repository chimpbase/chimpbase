{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["bun-types", "node"],
    "paths": {
      "@chimpbase/core": ["./packages/core/index.ts"],
      "@chimpbase/runtime": ["./packages/runtime/index.ts"],
      "@chimpbase/host": ["./packages/host/src/index.ts"],
      "@chimpbase/host/*": ["./packages/host/src/*"],
      "@chimpbase/bun": ["./packages/bun/src/library.ts"],
      "@chimpbase/deno": ["./packages/deno/src/library.ts"],
      "@chimpbase/node": ["./packages/node/src/library.ts"],
      "@chimpbase/postgres": ["./packages/postgres/src/index.ts"],
      "@chimpbase/tooling": ["./packages/tooling/src/index.ts"],
      "@chimpbase/tooling/*": ["./packages/tooling/src/*"]
    }
  },
  "include": [
    "packages/bun/**/*.ts",
    "packages/deno/**/*.ts",
    "packages/host/**/*.ts",
    "packages/node/**/*.ts",
    "packages/postgres/**/*.ts",
    "packages/tooling/**/*.ts",
    "tests/**/*.ts",
    "packages/core/**/*.ts",
    "packages/runtime/**/*.ts",
    "examples/**/*.ts"
  ]
}
