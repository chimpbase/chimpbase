{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["bun-types", "node"],
    "paths": {
      "@chimpbase/core": ["./packages/core/index.ts"],
      "@chimpbase/runtime": ["./packages/runtime/index.ts"],
      "@chimpbase/host": ["./packages/host/src/index.ts"],
      "@chimpbase/host/*": ["./packages/host/src/*"],
      "@chimpbase/bun": ["./packages/bun/src/library.ts"],
      "@chimpbase/deno": ["./packages/deno/src/library.ts"],
      "@chimpbase/node": ["./packages/node/src/library.ts"],
      "@chimpbase/postgres": ["./packages/postgres/src/index.ts"],
      "@chimpbase/rest-collections": ["./packages/rest-collections/src/index.ts"],
      "@chimpbase/tooling": ["./packages/tooling/src/index.ts"],
      "@chimpbase/tooling/*": ["./packages/tooling/src/*"],
      "@chimpbase/pact": ["./packages/pact/src/index.ts"],
      "@chimpbase/auth": ["./packages/auth/src/index.ts"],
      "@chimpbase/webhooks": ["./packages/webhooks/src/index.ts"],
      "@chimpbase/otel": ["./packages/otel/src/index.ts"]
    }
  },
  "include": [
    "packages/bun/**/*.ts",
    "packages/deno/**/*.ts",
    "packages/host/**/*.ts",
    "packages/node/**/*.ts",
    "packages/postgres/**/*.ts",
    "packages/rest-collections/**/*.ts",
    "packages/tooling/**/*.ts",
    "tests/**/*.ts",
    "packages/core/**/*.ts",
    "packages/runtime/**/*.ts",
    "packages/pact/**/*.ts",
    "packages/auth/**/*.ts",
    "packages/webhooks/**/*.ts",
    "packages/otel/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "examples/deno/**"
  ]
}
