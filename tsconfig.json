{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["bun-types", "node"],
    "paths": {
      "@chimpbase/core": ["./packages/core/index.ts"],
      "@chimpbase/runtime": ["./packages/runtime/index.ts"],
      "@chimpbase/bun": ["./packages/bun/src/library.ts"]
    }
  },
  "include": [
    "packages/bun/**/*.ts",
    "tests/**/*.ts",
    "packages/core/**/*.ts",
    "packages/runtime/**/*.ts",
    "examples/**/*.ts"
  ]
}
